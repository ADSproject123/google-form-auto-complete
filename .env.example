# Anthropic Claude API key (required if using Claude provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI Singapore SEA-LION API key (required if using SEA-LION provider)
# Get your key at: https://sea-lion.ai
SEALION_API_KEY=your_sealion_api_key_here

# ── Baray Payment Gateway ─────────────────────────────────────────────────────
# Get credentials at: https://dash.baray.io
BARAY_API_KEY=your_baray_api_key_here
BARAY_SK=your_baray_secret_key_base64_here
BARAY_IV=your_baray_iv_base64_here
BARAY_PAY_URL=https://api.baray.io/pay
BARAY_CHECKOUT_BASE_URL=https://pay.baray.io
BARAY_CHECK_URL=https://api.baray.io/payments/check/order
BARAY_CURRENCY=USD
BARAY_ORG_ID=your_baray_org_id_here

# Public base URL of this app — used to build the post-payment redirect URL.
# For local dev, use ngrok: ngrok http 3000  →  set APP_BASE_URL=https://xxxx.ngrok.io
# In production, set this to your deployed domain: https://yourdomain.com
APP_BASE_URL=http://localhost:3000